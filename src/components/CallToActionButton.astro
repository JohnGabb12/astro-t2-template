---
import { cn } from "~/lib/utils";

interface Props {
	text: string;
	href: string;
	variant?: "primary" | "secondary";
}
const { text, href, variant }: Props = Astro.props;
---

<a
	href={href}
	class={cn(
		"inline-flex items-center w-full md:mx-0 mx-auto sm:w-fit justify-center px-4 py-2 rounded font-semibold transition-colors duration-200 focus-visible:outline focus-visible:outline-offset-2",
		variant === "primary"
			? "bg-blue-600 text-white hover:bg-blue-700 focus-visible:outline-blue-600"
			: "bg-gray-200 text-gray-800 hover:bg-gray-300 focus-visible:outline-gray-400",
	)}
>
	{text}
</a>
