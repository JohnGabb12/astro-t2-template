---
import { Image } from "astro:assets";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import DEFAULT_TOPBAR_IMAGE from "~/assets/astro.png";
import { cn } from "~/lib/utils";
import {
	House,
	HandHeart,
	FolderBookmark,
	Info,
	UserRound,
} from "@lucide/astro";
import CTAButton from "~/components/CallToActionButton.astro";

const pathname = Astro.url.pathname;

const rawSegment = pathname.split("/").filter(Boolean)[0] || "";
const pageTitle = rawSegment
	? rawSegment
			.split("-")
			.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
			.join(" ")
	: "Home";

const DEFAULT_LINKS = [
	{ href: "/", label: "Home", icon: House },
	{ href: "/services", label: "Services", icon: HandHeart },
	{ href: "/projects", label: "Projects", icon: FolderBookmark },
	{ href: "/about", label: "About", icon: Info },
	{ href: "/contact", label: "Contact", icon: UserRound },
];

const {
	image = DEFAULT_TOPBAR_IMAGE,
	links = DEFAULT_LINKS,
	class: _class = "",
}: {
	image?: ImageMetadata;
	links?: { href: string; label: string; icon: AstroComponentFactory }[];
	class?: string;
} = Astro.props;
---

<script type="module" lang="ts">
	// This script is for the mobile navigation to hide if the user is seeing the footer.
	const mobileNav = document.getElementById("mobile-nav");

	if (!mobileNav) throw new Error("Mobile navigation element not found.");

	window.addEventListener('scroll', () => {
      if (window.scrollY >= document.documentElement.scrollHeight - (window.innerHeight * 1.25)) { // hide
        mobileNav.classList.add('opacity-0', 'pointer-events-none');
        mobileNav.classList.remove('opacity-100');
      } else { // show
        mobileNav.classList.remove('opacity-0', 'pointer-events-none');
        mobileNav.classList.add('opacity-100');
      }
    });
</script>

<header
	class={cn(
		"w-full bg-white border-b border-gray-100 px-4 py-3 sm:px-6 fixed top-0 left-0 z-50",
		_class,
	)}
>
	<div
		class="flex flex-row justify-between items-center max-w-7xl mx-auto gap-4"
	>
		{/* Brand Section */}
		<aside class="flex flex-row items-center gap-3 shrink-0">
			<a
				href="/"
				class="flex items-center gap-2 focus-visible:outline-blue-500"
				aria-label="Home page"
			>
				<Image src={image} alt="Logo" class="h-8 w-auto object-contain" />
			</a>
			<span
				class="hidden sm:inline-block text-sm font-medium text-gray-400 pointer-events-none"
				>|</span
			>
			<span class="hidden sm:inline-block text-sm font-medium text-gray-500"
				>{pageTitle}</span
			>
		</aside>

		{/* Navigation Menu */}
		<nav
			class="hidden md:flex flex-row items-center gap-6"
			aria-label="Main Navigation"
		>
			{
				links.map((link) => {
					const isActive =
						link.href === "/"
							? pathname === "/"
							: pathname.startsWith(link.href);

					return (
						<a
							href={link.href}
							class={cn(
								"text-sm font-medium flex flex-row gap-2 items-center transition-colors duration-200 focus-visible:outline-blue-500",
								isActive
									? "text-blue-500 font-semibold"
									: "text-gray-600 hover:text-blue-500",
							)}
						>
							{link.icon && <link.icon class="h-4 w-4" />}
							{link.label}
						</a>
					);
				})
			}
		</nav>

		{/* Primary Call to Action Button */}
		<div class="hidden sm:block w-fit">
			<CTAButton text="Join Now" href="/join" variant="primary" />
		</div>

		<nav
			class="flex md:hidden flex-row transition-opacity duration-300 items-center gap-6 fixed bottom-4 left-1/2 -translate-x-1/2 bg-white border border-gray-200 rounded-full px-6 py-2 shadow-lg z-50"
			id="mobile-nav"
			aria-label="Mobile Navigation"
		>
			{
				links.map((link) => {
					const isActive =
						link.href === "/"
							? pathname === "/"
							: pathname.startsWith(link.href);

					return (
						<a
							href={link.href}
							class={cn(
								"flex flex-col items-center text-xs transition-colors duration-200 focus-visible:outline-blue-500",
								isActive
									? "text-blue-500 font-semibold"
									: "text-gray-600 hover:text-blue-500",
							)}
						>
							{link.icon && <link.icon class="h-7 w-7 mb-1" />}
							{link.label}
						</a>
					);
				})
			}
		</nav>
	</div>
</header>
